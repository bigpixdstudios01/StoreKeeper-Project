# .env — Copy this file, rename it to .env, and fill in your values (local dev only).
# For Vercel: add SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY as Environment Variables instead.

PORT=3000

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# SECRET — backend only. NEVER put this in index.html or expose it to the frontend.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_SECRET_KEY
